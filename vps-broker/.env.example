# ======================================================================
# Broker MQTT VPS — konfigurasi
# Copy ke .env: cp .env.example .env  (run.sh otomatis melakukannya)
# ======================================================================

# Mode sertifikat TLS:
#   selfsigned  = dibuat sendiri (cepat, tanpa domain). Client pakai ca.crt
#                 atau setInsecure(). Cocok untuk mulai cepat.
#   letsencrypt = sertifikat terpercaya (butuh DOMAIN + port 80 + DNS A record).
#                 Client tak perlu file CA (root publik). Disarankan utk produksi.
TLS_MODE=selfsigned

# Domain broker. Untuk letsencrypt WAJIB. Untuk selfsigned dipakai sbg CN/SAN.
# Buat A record DNS-only (grey cloud di Cloudflare) → IP publik VPS ini.
DOMAIN=mqtt.trin-polman.id

# IP publik VPS (opsional, untuk SAN cert self-signed bila konek pakai IP).
# Biarkan kosong jika konek pakai DOMAIN saja.
PUBLIC_IP=

# Email untuk Let's Encrypt (mode letsencrypt).
LE_EMAIL=admin@trin-polman.id

# Kredensial MQTT (dipakai device ESP32 & backend trin).
MQTT_USER=aquaculture
MQTT_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
MQTT_PORT=8883
