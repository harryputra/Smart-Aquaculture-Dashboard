# ======================================================================
# Smart Aquaculture — konfigurasi environment
# ----------------------------------------------------------------------
# Copy file ini menjadi .env  →  `cp .env.example .env`
# (run.sh/run.bat melakukan ini otomatis bila .env belum ada).
#
# Nilai di bawah AMAN untuk LOKAL. Sebelum DEPLOY ke server, WAJIB ganti
# semua secret bertanda [GANTI] dengan nilai acak yang kuat.
# ======================================================================

# ----------------------------------------------------------------------
# Bind address & port host
# ----------------------------------------------------------------------
# PRODUKSI (./run.sh deploy): yang dipublikasikan ke host HANYA frontend
# (WEB_PORT) dan MQTT (MQTT_PORT). Port di bawahnya (DB/Influx/Grafana/backend)
# TIDAK dibuka ke host di produksi → tidak bentrok di VM yang dipakai banyak app.
#
# Frontend = service publik (diarahkan Cloudflare Tunnel → http://localhost:${WEB_PORT}).
# Di server trin: set WEB_PORT ke port host BEBAS (8088 & 33061 sudah dipakai).
WEB_BIND=127.0.0.1
WEB_PORT=3000

# MQTT broker TCP (1883) untuk ESP32 di LAN → biarkan 0.0.0.0.
# (Buka port 1883 di UFW pada VM agar ESP32 LAN bisa konek.)
MQTT_BIND=0.0.0.0
MQTT_PORT=1883

# MQTT over WebSocket (9001) → dipublish ke 127.0.0.1 untuk Cloudflare Tunnel.
# Inilah jalur ESP32 REMOTE (kolam jauh) via wss://mqtt.<domain> (port 443).
# Lihat docs/MQTT-WEBSOCKET-ESP32.md.
MQTT_WS_BIND=127.0.0.1
MQTT_WS_PORT=9001

# --- Port internal: HANYA berlaku di DEV LOKAL (docker-compose.debug.yml) ---
# Dipakai ./run.sh up untuk akses langsung dari host (psql/influx/grafana admin).
# Di produksi diabaikan. Ubah bila bentrok dengan app lain di mesin dev.
INFLUX_PORT=8086
DB_PORT=5432
GRAFANA_PORT=3001
BACKEND_PORT=5000

# ----------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------
DB_USER=aquaculture
DB_PASSWORD=aquaculture123       # [GANTI] sebelum deploy
DB_NAME=aquaculture

# ----------------------------------------------------------------------
# MQTT (Mosquitto)
# ----------------------------------------------------------------------
# Catatan: kredensial ini harus cocok dengan file mosquitto/config/passwd.
# Jika mengganti password MQTT, regenerasi passwd:
#   ./run.sh mqtt-passwd   (atau lihat README)
MQTT_USER=aquaculture
MQTT_PASSWORD=aquaculture123     # [GANTI] sebelum deploy (regenerasi passwd!)

# ----------------------------------------------------------------------
# InfluxDB v2
# ----------------------------------------------------------------------
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=admin123456   # [GANTI] sebelum deploy
INFLUX_ORG=aquaculture
INFLUX_BUCKET=sensor_data
INFLUX_TOKEN=my-super-secret-auth-token   # [GANTI] token acak panjang

# ----------------------------------------------------------------------
# Grafana
# ----------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123     # [GANTI] sebelum deploy
# Domain publik tempat app diakses + subpath /grafana/. Untuk server set ke
# domain Cloudflare, mis: https://aquaculture.trin-polman.id/grafana/
GRAFANA_ROOT_URL=http://localhost:3000/grafana/

# ----------------------------------------------------------------------
# Broker MQTT REMOTE untuk device lele (ESP32 di kolam jauh)
# ----------------------------------------------------------------------
# Device pakan lele ada di lokasi jauh dan TIDAK satu LAN dengan server.
# Pakai broker sendiri di VPS (lihat folder vps-broker/) yang reachable dari
# internet via TLS. Backend trin akan konek ke broker itu KHUSUS topik lele/#.
#
# Kosongkan LELE_MQTT_HOST untuk tetap pakai broker lokal (mosquitto) — cocok
# saat dev / belum ada device remote.
# Isi dgn domain/IP broker VPS, mis: mqtt.trin-polman.id
# (JANGAN taruh komentar di baris yang nilainya kosong — akan terbaca sbg nilai)
LELE_MQTT_HOST=
LELE_MQTT_PORT=8883
# mqtts (TLS) | mqtt (tanpa TLS — JANGAN dipakai lewat internet)
LELE_MQTT_PROTOCOL=mqtts
# samakan dengan user & password di broker VPS
LELE_MQTT_USER=aquaculture
LELE_MQTT_PASSWORD=
# Set true HANYA jika sertifikat broker self-signed (lewati verifikasi cert,
# trafik tetap terenkripsi). Jika pakai Let's Encrypt, biarkan false.
LELE_MQTT_TLS_INSECURE=false

# ----------------------------------------------------------------------
# Auth & akun admin (Fase 1 — login multi-user)
# ----------------------------------------------------------------------
# [GANTI] Rahasia penandatangan JWT — WAJIB string acak panjang di produksi.
#   Generate: openssl rand -hex 32
AUTH_SECRET=dev-secret-ganti-di-produksi
# Akun superadmin pertama (dibuat otomatis saat backend boot, idempoten).
# [GANTI] sebelum deploy. Jika password masih default, backend memperingatkan.
ADMIN_EMAIL=admin@aquaculture.local
ADMIN_PASSWORD=admin123

# ----------------------------------------------------------------------
# OTA firmware (update ESP32 jarak jauh)
# ----------------------------------------------------------------------
# Base URL PUBLIK (lewat Cloudflare) tempat device mengunduh .bin & cek manifest.
# Harus sama dengan domain dashboard (OTA_API_HOST di firmware).
OTA_PUBLIC_BASE=https://aquaculture.trin-polman.id
