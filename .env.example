# ======================================================================
# Smart Aquaculture — konfigurasi environment
# ----------------------------------------------------------------------
# Copy file ini menjadi .env  →  `cp .env.example .env`
# (run.sh/run.bat melakukan ini otomatis bila .env belum ada).
#
# Nilai di bawah AMAN untuk LOKAL. Sebelum DEPLOY ke server, WAJIB ganti
# semua secret bertanda [GANTI] dengan nilai acak yang kuat.
# ======================================================================

# ----------------------------------------------------------------------
# Bind address & port host
# ----------------------------------------------------------------------
# PRODUKSI (./run.sh deploy): yang dipublikasikan ke host HANYA frontend
# (WEB_PORT) dan MQTT (MQTT_PORT). Port di bawahnya (DB/Influx/Grafana/backend)
# TIDAK dibuka ke host di produksi → tidak bentrok di VM yang dipakai banyak app.
#
# Frontend = service publik (diarahkan Cloudflare Tunnel → http://localhost:${WEB_PORT}).
# Di server trin: set WEB_PORT ke port host BEBAS (8088 & 33061 sudah dipakai).
WEB_BIND=127.0.0.1
WEB_PORT=3000

# MQTT broker (1883) perlu diakses ESP32 di LAN → biarkan 0.0.0.0.
# (Buka port 1883 di UFW pada VM agar ESP32 bisa konek.)
MQTT_BIND=0.0.0.0
MQTT_PORT=1883

# --- Port internal: HANYA berlaku di DEV LOKAL (docker-compose.debug.yml) ---
# Dipakai ./run.sh up untuk akses langsung dari host (psql/influx/grafana admin).
# Di produksi diabaikan. Ubah bila bentrok dengan app lain di mesin dev.
MQTT_WS_PORT=9001
INFLUX_PORT=8086
DB_PORT=5432
GRAFANA_PORT=3001
BACKEND_PORT=5000

# ----------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------
DB_USER=aquaculture
DB_PASSWORD=aquaculture123       # [GANTI] sebelum deploy
DB_NAME=aquaculture

# ----------------------------------------------------------------------
# MQTT (Mosquitto)
# ----------------------------------------------------------------------
# Catatan: kredensial ini harus cocok dengan file mosquitto/config/passwd.
# Jika mengganti password MQTT, regenerasi passwd:
#   ./run.sh mqtt-passwd   (atau lihat README)
MQTT_USER=aquaculture
MQTT_PASSWORD=aquaculture123     # [GANTI] sebelum deploy (regenerasi passwd!)

# ----------------------------------------------------------------------
# InfluxDB v2
# ----------------------------------------------------------------------
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=admin123456   # [GANTI] sebelum deploy
INFLUX_ORG=aquaculture
INFLUX_BUCKET=sensor_data
INFLUX_TOKEN=my-super-secret-auth-token   # [GANTI] token acak panjang

# ----------------------------------------------------------------------
# Grafana
# ----------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123     # [GANTI] sebelum deploy
# Domain publik tempat app diakses + subpath /grafana/. Untuk server set ke
# domain Cloudflare, mis: https://aquaculture.trin-polman.id/grafana/
GRAFANA_ROOT_URL=http://localhost:3000/grafana/
